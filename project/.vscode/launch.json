{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Listen for Xdebug",
            "type": "php",
            "request": "launch",
            "port": 9003
        },
        {
            "name": "Open Current PHP Script",
            "type": "php",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "port": 9003,
            "runtimeExecutable": "/opt/homebrew/bin/php"
        },
        {
            "name": "Launch Built-in Server",
            "type": "php",
            "request": "launch",
            "runtimeArgs": [
                "-S",
                "127.0.0.1:8000",
                "-t",
                "${workspaceFolder}"
            ],
            "cwd": "${workspaceFolder}",
            "port": 9003,
            "serverReadyAction": {
                "pattern": "Development Server \\(http://127.0.0.1:8000\\) started",
                "uriFormat": "http://127.0.0.1:8000/index.php",
                "action": "openExternally"
            },
            "runtimeExecutable": "/opt/homebrew/bin/php"
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ],
    "compounds": [
        {
            "name": "Serve and Debug",
            "configurations": [
                "Listen for Xdebug",
                "Launch Built-in Server"
            ]
        }
    ]
}
