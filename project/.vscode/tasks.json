{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run PHP Server",
            "type": "shell",
            "command": "/opt/homebrew/bin/php",
            "args": [
                "-S",
                "127.0.0.1:8000",
                "-t",
                "${workspaceFolder}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "php-server",
                "pattern": {
                    "regexp": "."
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "PHP \\d+\\.\\d+\\.\\d+ Development Server",
                    "endsPattern": "Development Server \\(http://127.0.0.1:8000\\) started"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Lint All PHP Files",
            "type": "shell",
            "command": "find . -name '*.php' -print0 | xargs -0 -n1 /opt/homebrew/bin/php -l",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
